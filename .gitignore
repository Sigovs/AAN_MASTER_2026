# Dependencies (regenerated: npm install)
node_modules/

# Build output — ignore everything EXCEPT the compiled CSS, which is committed
# by design so the repo renders on GitHub / Pages without a build step.
dist/*
!dist/css/
dist/css/*
!dist/css/main.css

# Playwright self-check output
screenshots/

# Client-owned reference sources — MUST NEVER be published
reference/
FROM FERRARI/
FROM IVAYLO/

# OS junk
.DS_Store
Thumbs.db
desktop.ini
*.tmp
